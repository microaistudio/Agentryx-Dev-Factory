# Agentryx Dev Factory - Environment Configuration
# Copy this file to .env.factory and fill in your API keys

# GitHub Personal Access Token (for git push/PR operations)
# Required scopes: repo, workflow
GITHUB_PAT=

# Google Gemini API Key (for AI agent inference)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: WhatsApp Webhook URL (for notifications)
WHATSAPP_WEBHOOK=http://localhost:5678/webhook/factory-alert
